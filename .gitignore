*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Local datasets, generated runs, and scratch work
/data/
/datasets/
/downloads/
/derived/
/models/
/checkpoints/
/runs/
/outputs/
/scratch/
/tmp/

